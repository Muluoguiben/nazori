# Copy to .env.local and fill in, or set DEMO_MODE=1 to run without external APIs.

# OpenAI key for Whisper speech-to-text (/api/transcribe)
OPENAI_API_KEY=

# Anthropic key for Claude Sonnet 4.6 evaluation (/api/evaluate)
ANTHROPIC_API_KEY=

# Neon Postgres connection string for persistence.
# Run `npm run db:migrate` once with this set to create the tables.
DATABASE_URL=

# Long, random shared secret that gates the app (set this on Vercel).
# Unset = open access (handy for local dev). The first visit on each device
# asks for this once and stores a long-lived cookie.
APP_SECRET=

# Set to 1 to bypass external APIs and return canned transcript + evaluation.
# DEMO_MODE=1
